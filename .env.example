# Server
PORT=8080
TRUST_PROXY=1
CORS_ALLOWED_ORIGINS=https://netlab.tools,http://localhost:5173,http://127.0.0.1:5173
VITE_SITE_URL=https://netlab.tools
INDEXNOW_KEY=
LOG_LEVEL=info
CONSOLE_LOG_LEVEL=info
FILE_LOG_LEVEL=info
LOG_PRETTY_CONSOLE=false
NETLAB_IMAGE=your-registry.example.com/library/netlab:latest
WATCHTOWER_PORT=18081
WATCHTOWER_DOCKER_API_VERSION=1.40
WATCHTOWER_HTTP_API_UPDATE=true
WATCHTOWER_HTTP_API_TOKEN=

# Global API limit
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300

# Ping
PING_RATE_LIMIT_WINDOW_MS=900000
PING_RATE_LIMIT_MAX=90
PING_MAX_CONCURRENT_GLOBAL=20
PING_MAX_CONCURRENT_PER_IP=2

# DNS lookup and DNS server validation
DNS_RATE_LIMIT_WINDOW_MS=900000
DNS_RATE_LIMIT_MAX=60
DNS_LOOKUP_MAX_CONCURRENT_GLOBAL=20
DNS_LOOKUP_MAX_CONCURRENT_PER_IP=3

# DNS propagation
DNS_PROPAGATION_RATE_LIMIT_WINDOW_MS=900000
DNS_PROPAGATION_RATE_LIMIT_MAX=30
DNS_PROPAGATION_MAX_CONCURRENT_GLOBAL=8
DNS_PROPAGATION_MAX_CONCURRENT_PER_IP=2
DNS_PROPAGATION_QUERY_CONCURRENCY=10
DNS_PROPAGATION_QUERY_TIMEOUT_MS=4000

# Port scanning
PORT_SCAN_RATE_LIMIT_WINDOW_MS=900000
PORT_SCAN_RATE_LIMIT_MAX=20
PORT_SCAN_MAX_PORTS=256
PORT_SCAN_MAX_TIMEOUT_MS=2000
PORT_SCAN_MAX_CONCURRENT_GLOBAL=4
PORT_SCAN_MAX_CONCURRENT_PER_IP=1

# Trace and HTTP/TLS
TRACE_MAX_CONCURRENT_GLOBAL=12
TRACE_MAX_CONCURRENT_PER_IP=2
HTTP_INSPECTION_MAX_CONCURRENT_GLOBAL=16
HTTP_INSPECTION_MAX_CONCURRENT_PER_IP=3
WHOIS_MAX_CONCURRENT_GLOBAL=12
WHOIS_MAX_CONCURRENT_PER_IP=2
